{
  "name": "@hireahuman/sdk",
  "version": "0.1.0",
  "description": "Agent SDK for HireAHuman - Interact with human workers without native MCP support",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "npx tsx build.ts",
    "watch": "npx tsx build.ts --watch",
    "typecheck": "npx tsc --noEmit"
  },
  "keywords": [
    "hireahuman",
    "mcp",
    "agent",
    "sdk",
    "human-workers",
    "bounty",
    "tasks"
  ],
  "author": "HireAHuman",
  "license": "MIT",
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  }
}
