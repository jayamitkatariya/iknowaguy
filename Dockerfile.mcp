FROM node:20-alpine
WORKDIR /app
COPY package*.json ./
COPY packages/mcp-server/package*.json ./packages/mcp-server/
COPY packages/shared/package*.json ./packages/shared/
RUN npm install -ws
COPY . .
RUN cd packages/mcp-server && npm run build
EXPOSE 3001
CMD ["node", "packages/mcp-server/dist/index-http.js"]
