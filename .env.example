# iknowaguy — Environment Variables
# Copy to .env.local and fill in actual values

# Supabase (required by the platform)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (optional — stub mode works without it)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Notifications (optional)
NOTIFY_EMAIL_HOST=smtp.gmail.com
NOTIFY_EMAIL_PORT=587
NOTIFY_EMAIL_USER=notifications@iknowaguy.ai
NOTIFY_EMAIL_PASS=your-app-password
NOTIFY_EMAIL_FROM=iknowaguy <notifications@iknowaguy.ai>
NOTIFY_SLACK_WEBHOOK=https://hooks.slack.com/services/...
NOTIFY_TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234

# Node
NODE_ENV=development
