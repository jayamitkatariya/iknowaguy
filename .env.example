# iknowaguy — Environment Variables
# Copy to .env.local and fill in your actual values

# ============================================
# REQUIRED: Supabase (get from supabase.com)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# OPTIONAL: Stripe (for payments)
# Without these, payments run in stub/test mode
# ============================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# OPTIONAL: Notifications
# ============================================
# NOTIFY_EMAIL_HOST=smtp.gmail.com
# NOTIFY_EMAIL_PORT=587
# NOTIFY_EMAIL_USER=
# NOTIFY_EMAIL_PASS=
# NOTIFY_EMAIL_FROM=iknowaguy <notifications@example.com>
# NOTIFY_SLACK_WEBHOOK=

# ============================================
# Node Environment
# ============================================
NODE_ENV=development
