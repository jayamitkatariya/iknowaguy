{
  "name": "hireahuman",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source framework for AI agents to bring humans into the loop",
  "packages": [
    "packages/*"
  ],
  "scripts": {
    "build:all": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo clean && rm -rf node_modules .turbo",
    "setup": "pnpm install && pnpm build",
    "db:migrate": "psql $DATABASE_URL -f supabase/migrations/001_complete.sql",
    "db:seed": "psql $DATABASE_URL -f supabase/seed.sql",
    "test": "turbo test"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "5.4.5",
    "vitest": "^3.1.1"
  },
  "keywords": [
    "human-in-the-loop",
    "ai-agents",
    "mcp",
    "marketplace",
    "task-queue",
    "physical-world"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hireahuman/hireahuman"
  },
  "packageManager": "pnpm@10.21.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
